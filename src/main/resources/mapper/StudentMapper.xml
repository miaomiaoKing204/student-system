<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.studentsystem.mapper.StudentMapper">

    <!-- 结果映射 -->
    <resultMap id="studentResultMap" type="com.example.studentsystem.entity.Student">
        <id property="id" column="id"/>
        <result property="studentNo" column="student_no"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="className" column="class_name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!--查询所有学生 -->
    <select id="findAll" resultMap="studentResultMap">
        SELECT * FROM student
        ORDER BY create_time DESC
    </select>

    <!-- 根据ID查询学生 -->
    <select id="findById" resultMap="studentResultMap">
        SELECT * FROM student WHERE id = #{id}
    </select>

    <!-- 根据学号查询学生 -->
    <select id="findByStudentNo" resultMap="studentResultMap">
        SELECT * FROM student WHERE student_no = #{studentNo}
    </select>

    <!-- 模糊查询 -->
    <select id="search" resultMap="studentResultMap">
        SELECT * FROM student
        WHERE name LIKE CONCAT('%', #{keyword}, '%')
           OR student_no LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY create_time DESC
    </select>

    <!-- 添加学生 -->
    <insert id="insert" parameterType="com.example.studentsystem.entity.Student"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student (student_no, name, gender, class_name, phone, email)
        VALUES (#{studentNo}, #{name}, #{gender}, #{className}, #{phone}, #{email})
    </insert>

    <!-- 更新学生 -->
    <update id="update" parameterType="com.example.studentsystem.entity.Student">
        UPDATE student SET
                           student_no = #{studentNo},
                           name = #{name},
                           gender = #{gender},
                           class_name = #{className},
                           phone = #{phone},
                           email = #{email}
        WHERE id = #{id}
    </update>

    <!-- 删除学生 -->
    <delete id="deleteById">
        DELETE FROM student WHERE id = #{id}
    </delete>

    <!-- 统计学生总数 -->
    <select id="count" resultType="int">
        SELECT COUNT(*) FROM student
    </select>
</mapper>
